# Arkenos — Docker Compose Environment Variables
# Copy this file to .env and fill in your values:
#   cp .env.example .env
#
# Only 1 value is required. Everything else (LiveKit, Google, Resemble,
# Twilio, STT providers) is configured via the dashboard after first boot.
# Auth is handled by Better Auth using your Postgres database — no external keys needed.

# ── Required ─────────────────────────────────────────────────────────
POSTGRES_PASSWORD=arkenos

# ── Optional ─────────────────────────────────────────────────────────
# Override the default Better Auth session secret (recommended for production)
# BETTER_AUTH_SECRET=a-long-random-string
