# Arkenos — Docker Compose Environment Variables
# Copy this file to .env and fill in your values:
#   cp .env.example .env
#
# Only 3 values are required. Everything else (LiveKit, Google, Resemble,
# Twilio, STT providers) is configured via the dashboard after first boot.

# ── Required ─────────────────────────────────────────────────────────
POSTGRES_PASSWORD=changeme
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=pk_test_...
CLERK_SECRET_KEY=sk_test_...
