# Arkenos Agent Environment Variables
#
# The agent fetches all API keys from the backend dashboard on startup.
# No .env file is required if keys are configured in the dashboard.
#
# If you prefer to use env vars as fallback, copy this file to .env:
#   cp .env.example .env

# Backend URL (agent fetches API keys from the dashboard at boot)
BACKEND_API_URL=http://localhost:8000/api

# ── Optional fallback keys (dashboard takes priority) ────────────────
# These are only used if the corresponding key is NOT set in the dashboard.

# LiveKit Configuration
# LIVEKIT_API_KEY=your_livekit_api_key
# LIVEKIT_API_SECRET=your_livekit_api_secret
# LIVEKIT_URL=wss://your-server.livekit.cloud

# STT Providers (at least one required)
# ASSEMBLYAI_API_KEY=your_assemblyai_api_key
# DEEPGRAM_API_KEY=your_deepgram_api_key
# ELEVENLABS_API_KEY=your_elevenlabs_api_key

# Google Gemini (for LLM)
# GOOGLE_API_KEY=your_google_api_key

# Resemble AI (for Text-to-Speech)
# RESEMBLE_API_KEY=your_resemble_api_key
# RESEMBLE_PROJECT_UUID=your_project_uuid
# RESEMBLE_VOICE_UUID=your_voice_uuid
