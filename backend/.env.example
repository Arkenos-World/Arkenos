# Arkenos Backend Environment Variables
# Copy this file to .env and fill in your values

# Database
# Set your PostgreSQL password (used by Docker Compose and backend)
DB_PASSWORD=postgres
# Or override the full connection string directly:
# DATABASE_URL=postgresql://postgres:yourpassword@localhost:5432/arkenos

# LiveKit Configuration
# Get these from https://cloud.livekit.io
LIVEKIT_API_KEY=your_livekit_api_key
LIVEKIT_API_SECRET=your_livekit_api_secret
LIVEKIT_URL=wss://your-server.livekit.cloud

# Twilio Configuration
# Get these from https://console.twilio.com
TWILIO_ACCOUNT_SID=your_twilio_account_sid
TWILIO_AUTH_TOKEN=your_twilio_auth_token
TWILIO_SIP_DOMAIN=
# Optional: auto-derived from LIVEKIT_URL if not set

# LiveKit SIP Trunk ID (optional, auto-provisioned if empty)
LIVEKIT_SIP_TRUNK_ID=


# Resemble AI
# Get your API key from https://app.resemble.ai/account/api
RESEMBLE_API_KEY=your_resemble_api_key

# Google Gemini (for coding agent AI assistant)
# Get your API key from https://aistudio.google.com/apikey
GOOGLE_API_KEY=your_google_api_key

# MinIO (object storage for custom agent files)
MINIO_ENDPOINT=localhost:9000
MINIO_ACCESS_KEY=minioadmin
MINIO_SECRET_KEY=minioadmin
MINIO_BUCKET=arkenos

# Server Configuration
PORT=8000
DEBUG=true

# Frontend URL (for CORS)
FRONTEND_URL=http://localhost:3000
