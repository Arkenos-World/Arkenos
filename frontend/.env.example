# Arkenos Frontend Environment Variables
# Copy this file to .env.local and fill in your values

# ── Required ─────────────────────────────────────────────────────────

# Backend API URL
NEXT_PUBLIC_API_URL=http://localhost:8000/api

# ── Better Auth (set via docker-compose in Docker mode) ──────────────
# These are automatically set by docker-compose.yml.
# Only configure manually if running without Docker.
# BETTER_AUTH_SECRET=your-secret
# BETTER_AUTH_URL=http://localhost:4200
# DATABASE_URL=postgresql://postgres:password@localhost:5432/arkenos

# ── Optional ─────────────────────────────────────────────────────────

# Set to "false" to disable anonymous telemetry
# NEXT_PUBLIC_TELEMETRY=true
